MONGO_URL="mongodb://localhost:27017"
DB_NAME="chatflow_db"
JWT_SECRET="replace-with-a-strong-secret"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Comma-separated list for local + prod:
# Example: CORS_ORIGINS="http://localhost:3000,https://yourapp.vercel.app"
CORS_ORIGINS="http://localhost:3000"

# Email provider (recommended: API-based)
# - resend: set RESEND_API_KEY + EMAIL_FROM
# - sendgrid: set SENDGRID_API_KEY + EMAIL_FROM
# - smtp: legacy SMTP vars below
EMAIL_PROVIDER="resend"
EMAIL_FROM="ChatFlow <no-reply@yourdomain.com>"
RESEND_API_KEY="re_..."
SENDGRID_API_KEY=""

# SMTP (legacy / optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="starttls"
SMTP_USER="your@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="ChatFlow <your@gmail.com>"

# S3 uploads (required in production)
S3_BUCKET="your-bucket"
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
# Optional (recommended): public base URL for your bucket or CloudFront
S3_PUBLIC_BASE_URL="https://your-bucket.s3.ap-south-1.amazonaws.com"
