# =====================================================================
#  ChatFlow backend — environment variables
#
#  HOW TO USE
#   • LOCAL DEV  → copy this file to `backend/.env`, then swap the lines
#                  marked "RENDER" for the lines marked "LOCAL DEV".
#   • RENDER     → in Render → your Web Service → Environment, paste each
#                  KEY=VALUE pair (use "Add from .env" for bulk paste).
#
#  ⚠️  EVERY value that starts with `REPLACE_` MUST be replaced before
#      deploying. The app will not boot otherwise.
# =====================================================================


# ---------------------------------------------------------------------
#  1. Database — MongoDB Atlas
# ---------------------------------------------------------------------
#  Get the URI from Atlas → Connect → Drivers → Python.
#  Substitute REPLACE_USER / REPLACE_PASSWORD / REPLACE_CLUSTER with the
#  values shown by Atlas. URL-encode any special characters in the
#  password (@→%40, :→%3A, /→%2F, #→%23).
#
#  Example of a CORRECTLY filled value:
#    mongodb+srv://chatflow:MyPassw0rd@cluster0.ab12cde.mongodb.net/?retryWrites=true&w=majority&appName=ChatFlow
#
#  Atlas → Network Access → add 0.0.0.0/0 (or Render's outbound IPs),
#  otherwise the connection will time out.
MONGO_URL=mongodb+srv://REPLACE_USER:REPLACE_PASSWORD@REPLACE_CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=ChatFlow
DB_NAME=chatflow_db


# ---------------------------------------------------------------------
#  2. JWT secret
# ---------------------------------------------------------------------
#  Generate ONE strong random string and paste it here.
#    • macOS / Linux:   openssl rand -hex 48
#    • Windows (PS):    -join ((1..96) | % { '{0:x}' -f (Get-Random -Max 16) })
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING


# ---------------------------------------------------------------------
#  3. Seed administrator  (created only on the very first boot)
# ---------------------------------------------------------------------
#  Log in with ADMIN_PHONE + ADMIN_PASSWORD, then change the password
#  from the Profile dialog immediately.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeOnFirstLogin!
ADMIN_PHONE=+910000000001


# ---------------------------------------------------------------------
#  4. Session cookies
# ---------------------------------------------------------------------
#  RENDER (frontend lives on a different HTTPS domain → cross-site):
COOKIE_SECURE=true
COOKIE_SAMESITE=none
#  LOCAL DEV (http://localhost, swap the two lines above for these):
#COOKIE_SECURE=false
#COOKIE_SAMESITE=lax


# ---------------------------------------------------------------------
#  5. Allowed frontend origins  (CORS)
# ---------------------------------------------------------------------
#  Comma-separated list, NO trailing slash. List every frontend domain
#  that should be able to call this API. For installable Capacitor builds
#  talking to this same API, also include the WebView origins (even in prod):
#    http://localhost,capacitor://localhost,ionic://localhost
#  (defaults in server.py include those only when CORS_ORIGINS is unset.)
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost,capacitor://localhost,ionic://localhost
#  LOCAL DEV:
#CORS_ORIGINS=http://localhost:3000,capacitor://localhost,ionic://localhost


# ---------------------------------------------------------------------
#  6. Firebase Cloud Messaging (push notifications)
# ---------------------------------------------------------------------
#  OCI / VPS (recommended): absolute path to the service-account JSON on disk.
# FIREBASE_SERVICE_ACCOUNT_FILE=/home/ubuntu/chatflow/backend/firebase-adminsdk.json
#  Alternative: paste the full JSON as one line (no file on disk).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"chatflow-c61f0",...}
#  LOCAL DEV: leave both unset and place firebase-adminsdk.json in backend/ instead.
# FIREBASE_SERVICE_ACCOUNT_FILE=
# FIREBASE_SERVICE_ACCOUNT_JSON=


# ---------------------------------------------------------------------
#  7. File uploads — AWS S3   (required in production)
# ---------------------------------------------------------------------
#  Render's disk is ephemeral; uploads (avatars, voice notes, chat
#  attachments) MUST go to S3. Create an S3 bucket and an IAM user with
#  PutObject + GetObject on that bucket only.
S3_BUCKET=REPLACE_BUCKET_NAME
S3_REGION=ap-south-1
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_AWS_SECRET_KEY
#  Public read URL — usually `https://<bucket>.s3.<region>.amazonaws.com`
#  or your CloudFront domain. Update both bucket name and region.
S3_PUBLIC_BASE_URL=https://REPLACE_BUCKET_NAME.s3.ap-south-1.amazonaws.com


# ---------------------------------------------------------------------
#  7. Tunables   (safe defaults — change only if you know why)
# ---------------------------------------------------------------------
MIN_PASSWORD_LENGTH=6
#  ISO-2 country code used when a phone number is typed without "+<cc>".
#  IN = India, US = USA, GB = UK, AE = UAE, ...
DEFAULT_PHONE_COUNTRY=IN

# ---------------------------------------------------------------------
#  8. Admin storage dashboard (optional)
# ---------------------------------------------------------------------
#  Admin storage rings (defaults: Atlas 512 MB, S3 Standard 5 GB — omit to use built-ins).
#MONGO_STORAGE_QUOTA_BYTES=536870912
#S3_STORAGE_QUOTA_BYTES=5368709120
