MONGO_URL="mongodb://localhost:27017"
DB_NAME="chatflow_db"
JWT_SECRET="replace-with-a-strong-secret"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Comma-separated list for local + prod:
# Example: CORS_ORIGINS="http://localhost:3000,https://yourapp.vercel.app"
CORS_ORIGINS="http://localhost:3000"

# Email (Brevo) — sender must be a verified sender in Brevo (Campaigns → Senders)
BREVO_API_KEY="xkeysib-..."
SENDER_EMAIL="ChatFlow <no-reply@yourdomain.com>"

# S3 uploads (required in production)
S3_BUCKET="your-bucket"
# Region must match the bucket (Console: bucket → Properties → AWS Region). Use code e.g. ap-south-1, us-east-1.
S3_REGION="ap-south-1"
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
# Optional (recommended): public base URL for your bucket or CloudFront
S3_PUBLIC_BASE_URL="https://your-bucket.s3.ap-south-1.amazonaws.com"
