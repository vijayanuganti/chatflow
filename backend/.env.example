MONGO_URL="mongodb://localhost:27017"
DB_NAME="chatflow_db"
JWT_SECRET="replace-with-a-strong-secret"

# Seed administrator (only created on first boot)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
ADMIN_PHONE="+910000000001"

# Password policy
MIN_PASSWORD_LENGTH=6

# Default country code used when a phone number is entered without "+<cc>"
# Two-letter ISO code, e.g. IN, US, GB, AE
DEFAULT_PHONE_COUNTRY=IN

# Comma-separated CORS origins
# Example: CORS_ORIGINS="http://localhost:3000,https://yourapp.vercel.app"
CORS_ORIGINS="http://localhost:3000"

# Auth cookies
# - COOKIE_SECURE must be true on HTTPS (production). For local HTTP dev: false.
# - COOKIE_SAMESITE=strict only works when frontend & backend are same-site (recommended).
#   If your frontend and backend are on different domains, use COOKIE_SAMESITE=none (and COOKIE_SECURE=true).
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# S3 uploads (required in production)
S3_BUCKET="your-bucket"
# Region must match the bucket (Console: bucket → Properties → AWS Region). Use code e.g. ap-south-1, us-east-1.
S3_REGION="ap-south-1"
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
# Optional (recommended): public base URL for your bucket or CloudFront
S3_PUBLIC_BASE_URL="https://your-bucket.s3.ap-south-1.amazonaws.com"
