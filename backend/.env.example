# ====================================================================
#  ChatFlow — Backend environment
#  Copy this file to `.env` for local dev, or paste these keys into
#  Render → Web Service → Environment → "Add Environment Variable".
#
#  Variables marked  [REQUIRED]   must be set on Render.
#  Variables marked  [PROD ONLY]  are for production (HTTPS + Render).
#  Variables marked  [DEV ONLY]   are useful only on localhost.
#  Everything else has a safe default.
# ====================================================================


# --------------------------------------------------------------------
# 1. Database (MongoDB Atlas)  [REQUIRED]
# --------------------------------------------------------------------
# Atlas → Database → Connect → Drivers → copy the SRV URI.
# Replace <user>, <password> and <cluster> with your values.
# IMPORTANT: in Atlas → Network Access add "0.0.0.0/0" (allow from anywhere)
# or whitelist Render's outbound IPs, otherwise the backend cannot connect.
MONGO_URL="mongodb+srv://vijay_1508:vijay1403@cluster0.xdng5ju.mongodb.net/?appName=Cluster0"
DB_NAME="chat-flow-db"


# --------------------------------------------------------------------
# 2. JWT secret  [REQUIRED]
# --------------------------------------------------------------------
# Generate ONE strong random value and paste it here. Never reuse the
# example value. On any shell:
#   openssl rand -hex 48
# or (Windows PowerShell):
#   [Convert]::ToBase64String((1..48 | % { Get-Random -Max 256 } | % { [byte]$_ }))
JWT_SECRET=d5bc9411704a6fbac36f4b977166ceb373084ed2d3ba8a8a479a001d3c5ce794


# --------------------------------------------------------------------
# 3. Seed administrator  [REQUIRED]
# --------------------------------------------------------------------
# Created on the very first boot only. You will log in with the PHONE
# number (in E.164 form, e.g. +91XXXXXXXXXX). Change the password from
# the admin panel immediately after the first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PHONE=+910000000001


# --------------------------------------------------------------------
# 4. Cookies / sessions  [PROD ONLY]
# --------------------------------------------------------------------
# Production (Render backend + Vercel/Render frontend on a DIFFERENT
# domain over HTTPS):
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=none
#
# Local dev over plain http://localhost:
#   COOKIE_SECURE=false
#   COOKIE_SAMESITE=strict   (or "lax")
COOKIE_SECURE=true
COOKIE_SAMESITE=none


# --------------------------------------------------------------------
# 5. Allowed frontend origins  [REQUIRED]
# --------------------------------------------------------------------
# Comma-separated list, no trailing slash. Add every frontend URL that
# is allowed to talk to this API (Vercel preview + production, custom
# domain, etc.). Without this, the browser blocks the requests.
#   Example: https://chatflow.vercel.app,https://chatflow-staging.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.33:3000


# --------------------------------------------------------------------
# 6. File uploads — AWS S3  [REQUIRED in production]
# --------------------------------------------------------------------
# Render's filesystem is ephemeral, so chat attachments / voice notes /
# avatars MUST be stored in S3. Create:
#   - one S3 bucket (block public access OFF, or use a CloudFront URL)
#   - one IAM user with PutObject + GetObject on that bucket only
# Region must match the bucket region (ap-south-1, us-east-1, ...).
S3_BUCKET=my-admin-portal-storage-2026
S3_REGION=ap-south-1
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_AWS_SECRET_KEY
# Optional but recommended — the public base URL the browser will hit
# to read files. Use the bucket URL or a CloudFront distribution.
S3_PUBLIC_BASE_URL=https://my-admin-portal-storage-2026.s3.ap-south-1.amazonaws.com


# --------------------------------------------------------------------
# 7. Tunables  (safe defaults — only change if you need to)
# --------------------------------------------------------------------
# Minimum password length enforced when admins create accounts.
MIN_PASSWORD_LENGTH=6

# ISO-2 country code used when a phone is typed without a "+<cc>" prefix.
# IN = India, US = United States, GB = United Kingdom, AE = UAE, ...
DEFAULT_PHONE_COUNTRY=IN
