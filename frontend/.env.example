# ====================================================================
#  ChatFlow — Frontend environment (Create React App)
#
#  CRA reads these at BUILD TIME and bakes them into the bundle.
#  - Local dev:  copy this file to `frontend/.env`
#  - Render Static Site / Vercel: add the same keys as Build env vars
# ====================================================================


# --------------------------------------------------------------------
# Backend URL — web production  [REQUIRED for deployed static sites]
# --------------------------------------------------------------------
# Used when the app runs in a normal browser with NODE_ENV=production.
# NO trailing slash. Browser dev (npm start) ignores this and uses the
# dev-server host on port 8001 instead.
#   Render:  https://your-api.onrender.com
REACT_APP_BACKEND_URL=https://your-api.onrender.com

# --------------------------------------------------------------------
# Backend URL — Capacitor / physical device  [REQUIRED for APK/IPA]
# --------------------------------------------------------------------
# Baked at build time. Must NOT be localhost — use your PC's LAN IP.
#   • Local dev on a physical phone: http://192.168.x.x:8000 (match uvicorn port)
#   • Release APK for real users: same public HTTPS URL as REACT_APP_BACKEND_URL
# Optional alias (wins over everything if set):
# REACT_APP_BASE_URL=http://192.168.1.13:8000
REACT_APP_BACKEND_URL_MOBILE=http://192.168.1.13:8000


# --------------------------------------------------------------------
# Dev-server quirk  [DEV ONLY]
# --------------------------------------------------------------------
# Fixes the "websocket failed to connect" overlay on some CRA setups.
# Render/Vercel ignore this at build time.
WDS_SOCKET_PORT=0
